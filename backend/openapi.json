    "/api/verify": {
      "post": {
        "description": "Verify a filing's label image set against its expected application data.\n\nAccepts the full set of label images a COLA carries (repeated ``images``\nparts) \u2014 the mandatory content is split across them (warning on the back,\nABV on the front) \u2014 or a single ``image`` for older clients. Fields merge\non best verdict across the set; the result records which image each\nverdict came from.",
        "operationId": "verify_api_verify_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_verify_api_verify_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Verify",
        "tags": [
          "verification"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Liveness/readiness probe.\n\nExposed at the bare ``/health`` for the container healthcheck (which hits the\nbackend directly) and under ``/api/health`` so the browser can reach it via\nthe same ``/api`` reverse-proxy that fronts every other endpoint.",
        "operationId": "health_health_get",
        "responses": {
