            "title": "Match",
            "type": "integer"
          },
          "mismatch": {
            "default": 0,
            "title": "Mismatch",
            "type": "integer"
          },
          "not_checked": {
            "default": 0,
            "title": "Not Checked",
            "type": "integer"
          },
          "soft_warning": {
            "default": 0,
            "title": "Soft Warning",
            "type": "integer"
          }
        },
        "title": "VerdictSummary",
        "type": "object"
      },
      "VerificationImageInfo": {
        "description": "One image of the verified filing, with its readability grade.",
        "properties": {
          "filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Filename"
          },
          "index": {
            "title": "Index",
            "type": "integer"
          },
          "quality": {
            "$ref": "#/components/schemas/ImageQuality"
          }
        },
        "required": [
          "index",
          "filename",
          "quality"
        ],
        "title": "VerificationImageInfo",
        "type": "object"
      },
      "VerificationResponse": {
        "description": "The API response for one verification (a filing's full label set).\n\n``image_filename`` mirrors the first image for older clients; ``images``\nlists every uploaded label with its per-image readability. The result's\nfields carry ``image_index`` into this list.",
        "properties": {
          "application_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Application Id"
          },
          "image_filename": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Filename"
          },
          "image_quality": {
            "$ref": "#/components/schemas/ImageQuality"
          },
          "images": {
            "items": {
              "$ref": "#/components/schemas/VerificationImageInfo"
            },
            "title": "Images",
            "type": "array"
          },
          "result": {
            "$ref": "#/components/schemas/VerificationResult"
          },
          "status": {
            "$ref": "#/components/schemas/SubmissionStatus"
          },
          "submission_id": {
            "title": "Submission Id",
            "type": "integer"
          },
          "timing": {
            "$ref": "#/components/schemas/TimingInfo"
          }
        },
        "required": [
          "submission_id",
          "application_id",
          "status",
          "image_filename",
          "images",
          "timing",
          "result",
          "image_quality"
        ],
        "title": "VerificationResponse",
        "type": "object"
      },
      "VerificationResult": {
        "description": "The complete verification output for one label: the stable JSON contract.\n\nThis is what is persisted to ``Submission.result`` and rendered by the\ncomparison UI / batch results. It bundles the overall roll-up, every\nper-field result, the dedicated Government Health Warning result (kept\nseparate because it carries its own verdict vocabulary), a status summary,\nand a human-readable rationale for the overall verdict.",
        "properties": {
          "fields": {
            "items": {
              "$ref": "#/components/schemas/FieldResult"
            },
            "title": "Fields",
            "type": "array"
          },
          "government_warning": {
            "$ref": "#/components/schemas/GovernmentWarningResult"
          },
          "overall": {
            "$ref": "#/components/schemas/OverallVerdict"
          },
          "rationale": {
            "default": "",
            "title": "Rationale",
            "type": "string"
          },
          "schema_version": {
            "default": 2,
            "title": "Schema Version",
            "type": "integer"
          },
          "summary": {
            "$ref": "#/components/schemas/VerdictSummary"
          }
        },
        "required": [
          "overall",
          "government_warning",
          "summary"
        ],
        "title": "VerificationResult",
        "type": "object"
      },
      "WarningVerdict": {
        "description": "Outcome of the Government Health Warning check.\n\nMirrors ``tests.corpus.schema.WarningVerdict`` (the golden-data enum) so the\nverifier's output can be compared directly against the corpus expectations.",
        "enum": [
          "compliant",
          "altered",
          "missing"
        ],
        "title": "WarningVerdict",
        "type": "string"
      }
    }
  },
  "info": {
    "title": "TTB Label Verification API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/audit": {
      "get": {
        "description": "Newest-first audit trail, optionally scoped to one submission.",
        "operationId": "list_events_api_audit_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "maximum": 2000,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "submission_id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Submission Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AuditEventRow"
                  },
                  "title": "Response List Events Api Audit Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Events",
        "tags": [
          "audit"
        ]
      }
    },
    "/api/health": {
      "get": {
        "description": "Liveness/readiness probe.\n\nExposed at the bare ``/health`` for the container healthcheck (which hits the\nbackend directly) and under ``/api/health`` so the browser can reach it via\nthe same ``/api`` reverse-proxy that fronts every other endpoint.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/api/submissions": {
      "get": {
        "description": "Most recent submissions, newest first.",
        "operationId": "list_submissions_api_submissions_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 1000,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SubmissionRow"
                  },
                  "title": "Response List Submissions Api Submissions Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Submissions",
        "tags": [
          "submissions"
        ]
      }
    },
    "/api/submissions/stats": {
      "get": {
        "description": "Queue counts: pending, flagged for judgment, cleared this week, avg scan.",
        "operationId": "queue_stats_api_submissions_stats_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueStats"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Queue Stats",
        "tags": [
          "submissions"
        ]
      }
    },
    "/api/submissions/{submission_id}": {
      "get": {
        "description": "One submission with its persisted verification result.",
        "operationId": "get_submission_api_submissions__submission_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "submission_id",
            "required": true,
            "schema": {
              "title": "Submission Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionDetail"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Submission",
        "tags": [
          "submissions"
        ]
      }
    },
    "/api/submissions/{submission_id}/decision": {
      "post": {
        "description": "Record the reviewer's judgment; idempotent overwrite is allowed.",
        "operationId": "record_decision_api_submissions__submission_id__decision_post",
        "parameters": [
          {
            "in": "path",
            "name": "submission_id",
            "required": true,
            "schema": {
              "title": "Submission Id",
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecisionInput"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionDetail"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Record Decision",
        "tags": [
