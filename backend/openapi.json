      "BoundingBox": {
        "description": "Axis-aligned bounding box, derived from a detection polygon.\n\nMost downstream logic (reading order, region matching) only needs an\naxis-aligned box; the original :attr:`TextLine.polygon` is kept for callers\nthat care about rotation.",
        "properties": {
          "x_max": {
            "title": "X Max",
            "type": "number"
          },
          "x_min": {
            "title": "X Min",
            "type": "number"
          },
          "y_max": {
            "title": "Y Max",
            "type": "number"
          },
          "y_min": {
            "title": "Y Min",
            "type": "number"
          }
        },
        "required": [
          "x_min",
          "y_min",
          "x_max",
          "y_max"
        ],
        "title": "BoundingBox",
        "type": "object"
      },
      "DecisionInput": {
        "description": "The reviewer's decision plus an optional internal note.",
        "properties": {
