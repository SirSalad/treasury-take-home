# Copy to .env for local development.
# Backend service configuration.

# Postgres connection (matches docker-compose defaults).
# Uses the psycopg (v3) driver: postgresql+psycopg://...
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/labelverify

# CORS: comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# OCR / performance (see docs/perf.md).
# Warm the OCR model at startup so the first request isn't slow (set false for
# fast-iteration runs).
OCR_WARMUP=true
# Longest-side cap (px) applied to uploads before OCR; bounds latency on large
# photos. No-op for already-small labels.
OCR_MAX_SIDE=1600
# Recognition batch size for text-dense labels.
OCR_REC_BATCH_NUM=8
