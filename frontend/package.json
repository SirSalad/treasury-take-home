{
  "name": "label-verify-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered alcohol label verification UI (TTB prototype)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
